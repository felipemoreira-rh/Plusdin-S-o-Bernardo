rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ATENÇÃO: Estas regras permitem acesso aberto ao banco de dados.
    // Para produção, implemente Firebase Authentication e regras baseadas
    // em autenticação para proteger os dados adequadamente.
    //
    // Exemplo de regra segura (após implementar Firebase Auth):
    //   allow read, write: if request.auth != null;

    match /{document=**} {
      allow read, write: if request.time < timestamp.date(2027, 5, 13);
    }
  }
}
